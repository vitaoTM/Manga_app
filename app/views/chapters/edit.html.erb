<div class="max-w-2xl mx-auto px-6 py-10 text-slate-100">
  <%= link_to "← #{@manga.title}",
  manga_chapter_path(@manga, @chapter.url_number),
  class: "text-sm text-red-400 hover:text-red" %>

  <h1 class="text-3xl font-bold mt-4 mb-8">
    Edit Chapter —
    <span class="text-slate-400">
      <% if @chapter.title %>
        <%= @chapter&.title %>
      <% end %>
    </span>
  </h1>

  <div class="mt-10 border-t border-slate-700 pt-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold">
        Pages
        <span class="text-slate-500 font-normal text-sm ml-2">
          (<%= @chapter.page_count %>)
        </span>
      </h2>
      <%= link_to "Upload More",
      new_manga_chapter_page_path(@manga, @chapter.url_number),
      class:
        "text-xs bg-slate-700 hover:bg-slate-600 text-white
                                      px-3 py-1.5 rounded transition" %>
    </div>

    <% if @chapter.pages.any? %>
      <div class="grid grid-cols-4 sm:grid-cols-6 gap-3">
        <% @chapter.pages.ordered.each do |page| %>
          <div class="relative aspect-[2/3] bg-slate-800 rounded overflow-hidden group">

            <%# Thumbnail %>
            <% if page.image.attached? %>
              <%= image_tag page.image, class: "w-full h-full object-cover", loading: "lazy" %>
            <% end %>

            <%# Page number badge %>
            <span
              class="
                absolute top-1 left-1 bg-black/70 text-slate-300 text-[10px] font-bold px-1.5
                py-0.5 rounded
              "
            >
              <%= page.number %>
            </span>

            <%# Delete button — appears on hover %>
            <%= button_to manga_chapter_page_path(@manga, @chapter.url_number, page.number),
                  method: :delete,
                  data: { turbo_confirm: "Delete page #{page.number}?" },
                  class: "absolute inset-0 w-full h-full bg-black/0
                          group-hover:bg-black/50 transition-all duration-200
                          flex items-center justify-center
                          border-0 cursor-pointer" do %>
              <span
                class="
                  opacity-0 group-hover:opacity-100 transition-opacity bg-red-600 text-white
                  text-xs font-bold px-2 py-1 rounded
                "
              >
                Delete
              </span>
            <% end %>

          </div>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-10 text-slate-500 border border-slate-800 rounded">
        <p class="mb-3">No pages yet.</p>
        <%= link_to "Upload pages",
        new_manga_chapter_page_path(@manga, @chapter.url_number),
        class: "text-red-400 hover:text-red-300 text-sm underline" %>
      </div>
    <% end %>
  </div>

  <%# ── Danger zone ──────────────────────────────────────── %>
  <div class="mt-10 border-t border-slate-800 pt-6">
    <h3 class="text-red-400 font-semibold mb-3">Danger Zone</h3>
    <p class="text-slate-500 text-sm mb-4">
      Deleting this chapter will permanently remove all its pages and images.
    </p>
    <%= button_to "Delete Chapter",
    manga_chapter_path(@manga, @chapter.url_number),
    method: :delete,
    data: {
      turbo_confirm:
        "Delete chapter #{@chapter.display_title} and all its pages? This cannot be undone.",
    },
    class:
      "bg-red-900 hover:bg-red-700 text-red-300 hover:text-white
                              text-sm font-semibold px-4 py-2 rounded transition cursor-pointer" %>
  </div>

</div>
