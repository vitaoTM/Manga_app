<div
  <%# class="max-w-3/4 mx-auto px-4 py-8 bg-slate-950 min-h-screen text-slate-100" %>
  class="container mx-auto px-4 py-8 bg-slate-950 min-h-screen text-slate-100 relative"
  data-controller="scroll-to-top"
>

  <%# Scroll to Top Button %>
  <button
    type="button"
    data-scroll-to-top-target="button"
    data-action="click->scroll-to-top#scrollToTop"
    class="hidden fixed bottom-8 right-8 z-50 p-3 rounded-full bg-red-600 text-white shadow-lg hover:bg-red-500 transition-all focus:outline-none focus:ring-2 focus:ring-red-400 opacity-90 hover:opacity-100"
    aria-label="Scroll to top"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
    </svg>
  </button>

  <%# Header %>
  <div
    class="
      flex flex-col sm:flex-row items-center justify-between mb-6 pb-4 border-b
      border-slate-800 gap-4
    "
  >
    <div class="flex items-center justify-between w-full sm:w-auto gap-4">
      <%= link_to @manga.title.upcase,
      manga_path(@manga),
      class: "text-sm text-slate-400 hover:text-white  max-w-[150px] " %>

      <h1 class="text-lg font-bold overflow-hidden text-clip">
        <%= @chapter.display_title %>
      </h1>
    </div>

    <div
      class="flex items-center gap-2 w-full sm:w-auto justify-end"
      data-controller="navigation"
      data-navigation-base-url-value="<%= manga_path(@manga) %>"
    >
      <label class="text-[10px] text-slate-500 uppercase font-bold whitespace-nowrap">Jump to:</label>
      <%= select_tag :chapter_navigation,
      options_from_collection_for_select(
        @manga.chapters.published.ordered,
        :url_number,
        :display_title,
        @chapter.url_number.to_s,
      ),
      class:
        "bg-slate-800 border-slate-700 text-slate-200 text-xs rounded px-2 py-1 focus:ring-1 focus:ring-red-500 outline-none cursor-pointer w-full sm:w-auto",
      data: {
        action: "change->navigation#jump",
      } %>
    </div>
  </div>
  <div class="mt-4 mb-4">
    <%= render "ratings/form",
    manga: @manga,
    rating: user_signed_in? ? current_user.rating_for(@manga) : nil %>

  </div>

  <%# Admin controls %>
  <% if current_user&.admin? %>
    <div class="flex gap-3 mb-6">
      <%= link_to "Add Pages",
      new_manga_chapter_page_path(@manga, @chapter.url_number.to_s),
      class:
        "text-xs bg-slate-700 hover:bg-slate-600 text-white px-3 py-1.5 rounded transition" %>
      <%= link_to "Edit Chapter",
      edit_manga_chapter_path(@manga, @chapter.url_number.to_s),
      class:
        "text-xs bg-slate-700 hover:bg-slate-600 text-white px-3 py-1.5 rounded transition" %>
    </div>
  <% end %>

  <%# Pages — long scroll reader %>
  <% if @pages.any? %>
    <% @pages.each do |page| %>
      <% if page.image.attached? %>
        <%= image_tag page.image,
        class: "w-full mb-0.5 block",
        loading: "lazy",
        alt: "Page #{page.number}" %>
      <% end %>
    <% end %>
  <% else %>
    <div class="text-center py-24 text-slate-500">
      <p class="text-lg mb-2">No pages yet.</p>
      <% if current_user&.admin? %>
        <%= link_to "Upload pages",
        new_manga_chapter_page_path(@manga, @chapter.number),
        class: "text-red-400 hover:text-red-300 text-sm underline" %>
      <% end %>
    </div>
  <% end %>

  <%# Chapter navigation %>
  <div
    class="
      flex flex-col-reverse sm:flex-row justify-between mt-10 pt-6 border-t
      border-slate-800 text-sm gap-4
    "
  >
    <% if @prev_chapter %>
      <%= link_to manga_chapter_path(@manga, @prev_chapter.number),
            class: "text-slate-400 hover:text-white flex items-center justify-center sm:justify-start gap-2 bg-slate-900 sm:bg-transparent py-3 sm:py-0 rounded" do %>
        <span>←</span>
        <span class="truncate max-w-[200px]"><%= @prev_chapter.display_title %></span>
      <% end %>
    <% else %>
      <span></span>
    <% end %>

    <% if @next_chapter %>
      <%= link_to manga_chapter_path(@manga, @next_chapter.number),
            class: "text-slate-400 hover:text-white flex items-center justify-center sm:justify-end gap-2 bg-slate-900 sm:bg-transparent py-3 sm:py-0 rounded" do %>
        <span class="truncate max-w-[200px]"><%= @next_chapter.display_title %></span>
        <span>→</span>
      <% end %>
    <% else %>
      <span
        class="
          text-yellow-400 flex items-center justify-center sm:justify-end gap-2
        "
      >No further chapters yet</span>
    <% end %>
  </div>

</div>
