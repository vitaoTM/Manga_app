<div class="max-w-2xl mx-auto px-4 py-8 bg-zinc-950 min-h-screen text-zinc-100">

  <%# Header %>
  <div
    class="
      flex items-center justify-between mb-6 pb-4 border-b border-zinc-800
    "
  >
    <%= link_to @manga.title,
    manga_path(@manga),
    class: "text-sm text-zinc-400 hover:text-white truncate" %>
    <h1 class="text-lg font-bold ml-4 shrink-0">
      <%= @chapter.display_title %>
    </h1>
  </div>

  <%# Admin controls %>
  <% if current_user&.admin? %>
    <div class="flex gap-3 mb-6">
      <%= link_to "Add Pages",
      new_manga_chapter_page_path(@manga, @chapter.number),
      class:
        "text-xs bg-zinc-700 hover:bg-zinc-600 text-white
                          px-3 py-1.5 rounded transition" %>
    </div>
  <% end %>

  <%# Pages — long scroll reader %>
  <% if @pages.any? %>
    <% @pages.each do |page| %>
      <% if page.image.attached? %>
        <%= image_tag page.image,
        class: "w-full mb-0.5 block",
        loading: "lazy",
        alt: "Page #{page.number}" %>
      <% end %>
    <% end %>
  <% else %>
    <div class="text-center py-24 text-zinc-500">
      <p class="text-lg mb-2">No pages yet.</p>
      <% if current_user&.admin? %>
        <%= link_to "Upload pages",
        new_manga_chapter_page_path(@manga, @chapter.number),
        class: "text-red-400 hover:text-red-300 text-sm underline" %>
      <% end %>
    </div>
  <% end %>

  <%# Chapter navigation %>
  <div class="flex justify-between mt-10 pt-6 border-t border-zinc-800 text-sm">
    <% if @prev_chapter %>
      <%= link_to manga_chapter_path(@manga, @prev_chapter.number),
            class: "text-zinc-400 hover:text-white flex items-center gap-2" do %>
        <span>←</span>
        <span><%= @prev_chapter.display_title %></span>
      <% end %>
    <% else %>
      <span></span>
    <% end %>

    <% if @next_chapter %>
      <%= link_to manga_chapter_path(@manga, @next_chapter.number),
            class: "text-zinc-400 hover:text-white flex items-center gap-2 ml-auto" do %>
        <span><%= @next_chapter.display_title %></span>
        <span>→</span>
      <% end %>
    <% end %>
  </div>

</div>
