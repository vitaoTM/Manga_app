<div class="max-w-6xl mx-auto px-4 sm:px-6 py-10">
  <div class="mb-8 flex flex-col sm:flex-row items-center justify-between gap-2">
    <h1 class="text-3xl font-bold">My Library</h1>
    <span class="text-slate-500 text-sm">
      <%= @bookmarks.count %>
      <%= "manga".pluralize(@bookmarks.count) %>
    </span>
  </div>

  <% if @bookmarks.any? %>
    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-6 gap-4 sm:gap-5">
      <% @bookmarks.each do |bookmark| %>
        <% manga = bookmark.manga %>

        <div class="group relative">
          <%= link_to manga_path(manga), class: "block" do %>

            <%# Cover %>
            <div
              class="
                aspect-[2/3] bg-slate-800 rounded mb-2 border border-slate-700
                group-hover:border-slate-500 overflow-hidden transition-colors
              "
            >
              <% if manga.cover_image.attached? %>
                <%= image_tag manga.cover_image,
                class: "w-full h-full object-cover",
                loading: "lazy" %>
              <% else %>
                <div
                  class="
                    w-full h-full flex items-center justify-center text-slate-600 text-4xl
                  "
                >📖</div>
              <% end %>
            </div>

            <p
              class="
                text-sm font-semibold line-clamp-2 text-slate-200 group-hover:text-white
                transition-colors
              "
            >
              <%= manga.title %>
            </p>
            <p class="text-xs text-slate-500 mt-0.5"><%= manga.author %></p>
          <% end %>

          <div class="mt-4 mb-4">
            <%= render "ratings/form",
            manga: manga,
            rating: user_signed_in? ? current_user.rating_for(@manga) : nil %>

          </div>
          <%# Resume reading button %>
          <% progress = current_user.progress_for(manga) %>
          <% if progress %>
            <div class="mt-2">
              <%= link_to manga_chapter_path(manga, progress.chapter.url_number),
                    class: "block text-center text-xs bg-red-600 hover:bg-red-500
                            text-white py-1 rounded transition" do %>
                Resume Ch.
                <%= progress.chapter.url_number %>
              <% end %>
            </div>
          <% else %>
            <% first_chapter = manga.chapters.published.ordered.first %>
            <% if first_chapter %>
              <div class="mt-2">
                <%= link_to manga_chapter_path(manga, first_chapter.url_number),
                      class: "block text-center text-xs bg-slate-700 hover:bg-slate-600
                              text-slate-300 py-1 rounded transition" do %>
                  Start Reading
                <% end %>
              </div>
            <% end %>
          <% end %>

          <%# Remove from library %>
          <%= button_to bookmark_manga_path(manga),
                method: :delete,
                class: "absolute top-1 right-1 w-6 h-6 rounded-full bg-black/70
                        text-slate-400 hover:text-red-400 text-xs font-bold
                        opacity-0 group-hover:opacity-100 transition-all
                        flex items-center justify-center cursor-pointer border-0" do %>
            ✕
          <% end %>
        </div>

      <% end %>
    </div>
  <% else %>
    <div class="text-center py-24 text-slate-500 border border-slate-800 rounded">
      <p class="text-lg mb-2">Your library is empty.</p>
      <p class="text-sm mb-6">Bookmark manga to save them here.</p>
      <%= link_to "Browse Manga",
      mangas_path,
      class:
        "bg-red-600 hover:bg-red-500 text-white text-sm
                                                              font-semibold px-4 py-2 rounded transition" %>
    </div>
  <% end %>

</div>
