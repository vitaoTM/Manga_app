<nav class="bg-slate-900 border-b border-slate-800" data-controller="navbar">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <div class="flex items-center">
        <div class="flex-shrink-0">
          <% if current_user && current_user.admin? %>
            <%= link_to "Admin",
            admin_dashboard_path,
            class:
              "text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-500 to-purple-500" %>
          <% else %>
            <%= link_to "MangaApp", root_path,
            class:
              "text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-indigo-500 to-purple-500" %>
          <% end %>
        </div>

        <div class="hidden md:block">
          <div class="ml-10 flex items-baseline space-x-4">
            <%= link_to "Discover",
            root_path,
            class:
              "text-gray-300 hover:bg-slate-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200" %>

            <%= link_to "Tags",
            tags_path,
            class:
              "text-gray-300 hover:bg-slate-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200" %>

            <% if user_signed_in? %>
              <%= link_to "My Library",
              library_path,
              class:
                "text-gray-300 hover:bg-slate-800 hover:text-white px-3 py-2 rounded-md text-sm font-medium transition-colors duration-200" %>
            <% end %>
          </div>
        </div>
      </div>

      <div class="hidden md:block">
        <div class="ml-4 flex items-center md:ml-6">
          <% if user_signed_in? %>
            <span class="text-slate-400 text-sm mr-4">
              Hello,
              <%= link_to current_user.username, edit_user_registration_path, class: "hover:text-white" %>
            </span>
            <%= link_to "♥ Donate",
            new_donation_path,
            class: "text-sm text-red-400 hover:text-red-300 font-semibold px-3" %>

            <%= button_to "Sign out",
            destroy_user_session_path,
            method: :delete,
            class:
              "text-gray-300 hover:text-white text-sm font-medium bg-slate-800 hover:bg-slate-700 px-4 py-2 rounded-md transition-all cursor-pointer" %>

          <% else %>
            <div class="space-x-4">
              <%= link_to "Log in",
              new_user_session_path,
              class: "text-gray-300 hover:text-white text-sm font-medium" %>
              <%= link_to "Sign up",
              new_user_registration_path,
              class:
                "bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-md text-sm font-medium transition-colors" %>
            </div>
          <% end %>
        </div>
      </div>

      <div class="-mr-2 flex md:hidden">
        <button
          type="button"
          class="
            bg-slate-800 inline-flex items-center justify-center p-2 rounded-md
            text-gray-400 hover:text-white hover:bg-slate-700 focus:outline-none
          "
          aria-controls="mobile-menu"
          aria-expanded="false"
          data-action="click->navbar#toggle"
        >
          <span class="sr-only">Open main menu</span>
          <svg
            class="block h-6 w-6"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
            data-navbar-target="openIcon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"
            />
          </svg>
          <svg
            class="hidden h-6 w-6"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
            data-navbar-target="closeIcon"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <%# Mobile menu %>
  <div class="hidden md:hidden bg-slate-900 border-t border-slate-800" id="mobile-menu" data-navbar-target="menu">
    <div class="px-2 pt-2 pb-3 space-y-1 sm:px-3">
      <%= link_to "Discover", root_path, class: "text-gray-300 hover:bg-slate-800 hover:text-white block px-3 py-2 rounded-md text-base font-medium" %>
      <%= link_to "Tags", tags_path, class: "text-gray-300 hover:bg-slate-800 hover:text-white block px-3 py-2 rounded-md text-base font-medium" %>
      <% if user_signed_in? %>
        <%= link_to "My Library", library_path, class: "text-gray-300 hover:bg-slate-800 hover:text-white block px-3 py-2 rounded-md text-base font-medium" %>
        <%= link_to "♥ Donate", new_donation_path, class: "text-red-400 hover:bg-slate-800 hover:text-red-300 block px-3 py-2 rounded-md text-base font-medium" %>
      <% end %>
    </div>
    <div class="pt-4 pb-3 border-t border-slate-800">
      <% if user_signed_in? %>
        <div class="flex items-center px-5">
          <div class="text-base font-medium leading-none text-white"><%= current_user.username %></div>
        </div>
        <div class="mt-3 px-2 space-y-1">
          <%= link_to "Your Profile", edit_user_registration_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-slate-800" %>
          <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "block w-full text-left px-3 py-2 rounded-md text-base font-medium text-gray-400 hover:text-white hover:bg-slate-800" %>
        </div>
      <% else %>
        <div class="px-5 space-y-1">
          <%= link_to "Log in", new_user_session_path, class: "block px-3 py-2 rounded-md text-base font-medium text-gray-300 hover:text-white hover:bg-slate-800" %>
          <%= link_to "Sign up", new_user_registration_path, class: "block px-3 py-2 rounded-md text-base font-medium bg-indigo-600 text-white hover:bg-indigo-700" %>
        </div>
      <% end %>
    </div>
  </div>
</nav>
