<div class="max-w-6xl mx-auto space-y-4 py-10 px-4 sm:px-6">
  <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-6">
    <h1 class="text-3xl font-bold text-slate-100">Tags</h1>
    <% if current_user&.admin? %>
      <%= link_to "New Tag",
      new_tag_path,
      class:
        "w-full sm:w-auto text-center bg-red-600 hover:bg-red-500 text-white text-sm font-semibold px-6 py-2 rounded transition shadow-sm" %>
    <% end %>
  </div>

  <div class='space-y-3'>
    <% @tags.each do |tag| %>
      <div
        class="
          flex flex-col sm:flex-row sm:items-center justify-between bg-slate-800/50
          hover:bg-slate-800 transition-colors rounded-lg px-4 py-3 border
          border-slate-700/50 gap-3
        "
      >
        <div class="flex items-center gap-3">
          <span class="text-indigo-400 font-bold">#</span>
          <%= link_to tag.name,
          tag_path(tag),
          class: "text-slate-200 font-semibold hover:text-white transition-colors" %>
        </div>

        <div
          class='
            flex items-center justify-between sm:justify-end gap-6 w-full sm:w-auto
          '
        >
          <span
            class="
              text-xs font-medium text-slate-500 bg-slate-900/50 px-2 py-1 rounded
            "
          >
            <%= tag.mangas.count %>
            <%= "manga".pluralize(tag.mangas.count) %>
          </span>

          <% if current_user&.admin? %>
            <div class="flex items-center gap-4 text-sm font-medium">
              <%= link_to "Edit",
              edit_tag_path(tag),
              class: "text-slate-400 hover:text-white transition-colors" %>
              <%= button_to "Delete",
              tag_path(tag),
              method: :delete,
              data: {
                turbo_confirm: "Delete ##{tag.name}?",
              },
              class:
                "text-red-400 hover:text-red-300 bg-transparent border-0 cursor-pointer transition-colors" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
