<%= form_with model: tag, class: "space-y-4 max-w-sm" do |f| %>
  <% if tag.errors.any? %>
    <div
      class="
        bg-red-900/40 border border-red-700 rounded p-4 text-red-300 text-sm
      "
    >
      <% tag.errors.full_messages.each do |msg| %>
        <p><%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div>
    <%= f.label :name, class: "block text-sm font-medium text-zinc-300 mb-1" %>
    <p class="text-xs text-zinc-500 mb-2">
      Saved lowercase automatically — "Action" becomes "action"
    </p>
    <%= f.text_field :name,
                 autofocus: true,
                 class:
                   "w-full bg-zinc-800 border border-zinc-700 rounded
                              px-3 py-2 text-zinc-100 text-sm outline-none
                              focus:border-zinc-500" %>
  </div>

  <%= f.submit tag.persisted? ? "Update Tag" : "Create Tag",
           class:
             "bg-red-600 hover:bg-red-500 text-white font-semibold
                      py-2 px-6 rounded transition cursor-pointer" %>
<% end %>
