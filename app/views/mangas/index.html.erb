<div class="min-h-screen bg-slate-950 text-slate-100 px-6 py-10">

  <%# Header %>
  <% if current_user&.admin? %>
    <div class="max-w-6xl mx-auto mb-8 flex items-center justify-between">
      <%= link_to "New Manga",
      new_manga_path,
      class:
        "bg-red-600 hover:bg-red-500 text-white text-sm font-semibold px-4 py-2 rounded transition-colors" %>
    </div>
  <% end %>

  <%# Flash messages %>
  <div class="max-w-6xl mx-auto mb-6">
    <% flash.each do |type, msg| %>
      <div
        class="
          px-4 py-3 rounded text-sm
          <%= type == 'notice' ? 'bg-emerald-900/40 border border-emerald-700 text-emerald-300' : 'bg-red-900/40 border border-red-700 text-red-300' %>
        "
      >
        <%= msg %>
      </div>
    <% end %>
  </div>

  <%# Main Grid %>
  <div class="max-w-6xl mx-auto">
    <% if @mangas.any? %>
      <div
        class="
          grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6
          gap-x-4 gap-y-8
        "
      >
        <% @mangas.each do |manga| %>
          <%= link_to manga_path(manga), class: "group block" do %>
            <%# Cover %>
            <div
              class="
                aspect-[2/3] bg-slate-800 rounded overflow-hidden mb-2 border border-slate-700
                group-hover:border-slate-500 transition-colors duration-200
              "
            >
              <% if manga.cover_image.attached? %>
                <%= image_tag manga.cover_image.variant(resize_to_fill: [200, 300]).processed,
                alt: manga.title,
                # loading: "lazy",
                class: "w-full h-full object-cover" %>
              <% else %>
                <div
                  class="
                    w-full h-full flex items-center justify-center text-slate-600 text-4xl
                  "
                >
                  📖
                </div>
              <% end %>
            </div>

            <%# Info %>
            <p
              class="
                text-sm font-semibold text-slate-200 line-clamp-2 leading-snug
                group-hover:text-white transition-colors
              "
            >
              <%= manga.title %>
            </p>
            <p class="text-xs text-slate-500 mt-0.5"><%= manga.author %></p>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-24 text-slate-500">
        <p class="text-lg mb-4">No manga yet.</p>
        <%= link_to "Add the first one",
        new_manga_path,
        class: "text-red-500 hover:text-red-400 font-semibold underline" %>
      </div>
    <% end %>
  </div>

</div>
