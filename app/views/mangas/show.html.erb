<div class="min-h-screen bg-slate-950 text-slate-100 px-6 py-10">

  <%# Header %>
  <div class="max-w-6xl mx-auto mb-8 flex items-center justify-between">
    <%= link_to "<- Back",
    mangas_path,
    class:
      "bg-red-600 hover:bg-red-500 text-white text-sm font-semibold px-4 py-2 rounded transition-colors" %>

    <%# Bookmark button — signed in users only %>
    <% if user_signed_in? %>
      <% if current_user.bookmarked?(@manga) %>
        <%= button_to "♥ In Library",
        bookmark_manga_path(@manga),
        method: :delete,
        class:
          "bg-red-600 hover:bg-red-500 text-white text-sm font-semibold px-4 py-2 rounded transition cursor-pointer" %>
      <% else %>
        <%= button_to "♡ Add to Library",
        bookmark_manga_path(@manga),
        method: :post,
        class:
          "bg-slate-700 hover:bg-slate-600 text-slate-200 text-sm font-semibold px-4 py-2 rounded transition cursor-pointer" %>
      <% end %>
    <% end %>
  </div>

  <div
    class="
      mt-4 mb-4 max-w-6xl mx-auto mb-8 flex items-center justify-between relative flex
    "
  >
    <%= render "ratings/form",
    manga: @manga,
    rating: user_signed_in? ? current_user.rating_for(@manga) : nil %>

  </div>

  <span class= 'max-w-6xl mx-auto mb-8 flex items-center justify-between relative flex '><%= status_badge(@manga) %></span>
  <div
    class="
      max-w-6xl mx-auto mb-8   relative flex flex-col
      md:flex-row w-full my-6 bg-slate-900 shadow-sm border border-slate-950 rounded-xl
      w-96
    "
  >
    <div class="relative p-2.5 md:w-2/5 shrink-0 overflow-hidden">
      <% if @manga.cover_image.attached? %>
        <p><%= image_tag @manga.cover_image.variant(resize_to_fill: [300, 455]).processed,
          class: "py-6 px-4 cover_image" %></p>
      <% else %>
        <%= image_tag "nocover.jpg", class: "w-[300px] h-[400px]" %>
      <% end %>
    </div>

    <div class="p-6">
      <h1 class='text-4xl font-bold mt-4'><%= @manga.title %></h1>
      <div class="text-slate-700 text-base">
        <% if not @manga.description.blank? %>
          <p class='mt-6 text-slate-300 text-justify'>Description:
            <%= @manga.description %></p>
        <% end %>
      </div>

    </div>

  </div>
  <p class="text-slate-400 mt-1 max-w-6xl mx-auto mb-8 flex items-center justify-between relative flex ">Author:
    <%= @manga.author %></p>
  <% if @manga.tags.any? %>
    <div class="flex flex-wrap gap-2 max-w-6xl mx-auto mb-8 flex items-center justify-between relative flex 
">
      <% @manga.tags.each do |tag| %>
        <%= link_to "##{tag.name}",
        tag_path(tag),
        class:
        "text-xs px-2.5 py-1 bg-slate-800 hover:bg-slate-700 border border-slate-700 hover:border-slate-500 rounded-full text-slate-400 hover:text-slate-200 transition" %>
      <% end %>
    </div>
  <% end %>
  <%# Chapter list %>
  <div class="max-w-6xl mx-auto mt-10">

    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold">
        Chapters
        <span class="text-slate-500 font-normal text-sm ml-2">
          (<%= @manga.total_chapters %>)
        </span>
      </h2>
      <% if current_user&.admin? %>
        <%= link_to "Add Chapter",
        new_manga_chapter_path(@manga),
        class:
          "text-xs bg-red-600 hover:bg-red-500 text-white
                                                                                                                                                                                                      px-3 py-1.5 rounded transition" %>
      <% end %>
    </div>

    <% if @chapters.any? %>
      <div
        class="
          divide-y divide-slate-800 border border-slate-800 rounded overflow-hidden
        "
      >
        <% @chapters.each do |chapter| %>
          <%= link_to manga_chapter_path(@manga, chapter.number.to_i == chapter.number ? chapter.number.to_i : chapter.number),
                class: "flex items-center justify-between px-4 py-3
                        bg-slate-900 hover:bg-slate-800 transition group block" do %>

            <div class="flex items-center gap-4">
              <%# Chapter number badge %>
              <span class="text-xs font-mono text-slate-500 w-8 shrink-0">
                <%= chapter.number.to_i == chapter.number ? chapter.number.to_i : chapter.number %>
              </span>
              <%# Title %>
              <span
                class="
                  text-sm font-medium text-slate-200 group-hover:text-white transition
                "
              >
                <%= chapter.display_title %>
              </span>
            </div>

            <div class="flex items-center gap-4 text-xs text-slate-500 shrink-0">
              <span><%= chapter.page_count %>
                pages</span>
              <span><%= chapter.published_at&.strftime("%b %d, %Y") %></span>
              <span class="text-slate-600">→</span>
            </div>

          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 text-slate-500 border border-slate-800 rounded">
        <p class="mb-2">No chapters published yet.</p>
        <% if current_user&.admin? %>
          <%= link_to "Add the first chapter",
          new_manga_chapter_path(@manga),
          class: "text-red-400 hover:text-red-300 text-sm underline" %>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
