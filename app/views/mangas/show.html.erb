<div class="min-h-screen bg-slate-950 text-zinc-100 px-6 py-10">

  <%# Header %>
  <div class="max-w-6xl mx-auto mb-8 flex items-center justify-between">
    <%= link_to "<- Back",
    mangas_path,
    class:
      "bg-red-600 hover:bg-red-500 text-white text-sm font-semibold px-4 py-2 rounded transition-colors" %>
  </div>

  <h1 class='text-4xl font-bold mt-4'><%= @manga.title %></h1>
  <%# link_to @manga.chapters %>
  <% if @manga.cover_image.attached? %>
    <p><%= image_tag @manga.cover_image.variant(resize_to_fill: [300, 400]),
      class: "cover_image" %></p>
  <% end %>
  <p class="text-zinc-400 mt-1">Author:
    <%= @manga.author %></p>

  <span class='inline-block mt-3 px-3 py-1 text-xs rounded bg-red-600 text-white'><%= @manga.status.humanize %></span>
  <p class='mt-6 text-zinc-300'><%= @manga.description %></p>
  <div class='mt-8 flex gap-4'>
    <%= link_to "Edit",
    edit_manga_path(@manga),
    class: "px-4 py-2 bg-slate-700 rounded text-sm" %>
    <%= button_to "Delete",
    manga_path(@manga),
    method: :delete,
    data: {
      confirm: "Are you sure?",
    },
    class: "px-4 py-2 bg-red-700 rounded text-sm text-white" %>

  </div>
