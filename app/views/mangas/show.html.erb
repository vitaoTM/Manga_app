<div class="min-h-screen bg-slate-950 text-slate-100 px-6 py-10">

  <%# Header %>
  <div class="max-w-6xl mx-auto mb-8 flex items-center justify-between">
    <%= link_to "<- Back",
    mangas_path,
    class:
      "bg-red-600 hover:bg-red-500 text-white text-sm font-semibold px-4 py-2 rounded transition-colors" %>
  </div>

  <span class='inline-block mt-3 px-3 py-1 text-xs rounded bg-green-600 text-white'><%= @manga.status.humanize %></span>
  <div
    class="
      relative flex flex-col md:flex-row w-full my-6 bg-slate-900 shadow-sm border
      border-slate-950 round-lg w-96
    "
    >
    <div class="relative p-2.5 md:w-2/5 shrink-0 overflow-hidden">
      <% if @manga.cover_image.attached? %>
        <p><%= image_tag @manga.cover_image.variant(resize_to_fill: [300, 400]),
          class: "py-6 cover_image" %></p>
      <% else %>
        <%= image_tag "nocover.jpg", class: "w-[300px] h-[400px]" %>
      <% end %>
    </div>

    <div class="p-6">
      <h1 class='text-4xl font-bold mt-4'><%= @manga.title %></h1>
      <div class="text-slate-700 text-base">
        <p class='mt-6 text-slate-300'>Description:
      </div>
      <%= @manga.description %></p>
    </div>

  </div>
  <p class="text-slate-400 mt-1">Author:
    <%= @manga.author %></p>

  <%# Chapter list %>
  <div class="max-w-6xl mx-auto mt-10">

    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold">
        Chapters
        <span class="text-zinc-500 font-normal text-sm ml-2">
          (<%= @manga.total_chapters %>)
        </span>
      </h2>
      <% if current_user&.admin? %>
        <%= link_to "Add Chapter",
              new_manga_chapter_path(@manga),
              class: "text-xs bg-red-600 hover:bg-red-500 text-white
                      px-3 py-1.5 rounded transition" %>
      <% end %>
    </div>

    <% if @chapters.any? %>
      <div class="divide-y divide-zinc-800 border border-zinc-800 rounded overflow-hidden">
        <% @chapters.each do |chapter| %>
          <%= link_to manga_chapter_path(@manga, chapter.number),
                class: "flex items-center justify-between px-4 py-3
                        bg-zinc-900 hover:bg-zinc-800 transition group block" do %>

            <div class="flex items-center gap-4">
              <%# Chapter number badge %>
              <span class="text-xs font-mono text-zinc-500 w-8 shrink-0">
                <%= chapter.number.to_i == chapter.number ? chapter.number.to_i : chapter.number %>
              </span>
              <%# Title %>
              <span class="text-sm font-medium text-zinc-200 group-hover:text-white transition">
                <%= chapter.display_title %>
              </span>
            </div>

            <div class="flex items-center gap-4 text-xs text-zinc-500 shrink-0">
              <span><%= chapter.page_count %> pages</span>
              <span><%= chapter.published_at&.strftime("%b %d, %Y") %></span>
              <span class="text-zinc-600">→</span>
            </div>

          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="text-center py-12 text-zinc-500 border border-zinc-800 rounded">
        <p class="mb-2">No chapters published yet.</p>
        <% if current_user&.admin? %>
          <%= link_to "Add the first chapter",
                new_manga_chapter_path(@manga),
                class: "text-red-400 hover:text-red-300 text-sm underline" %>
        <% end %>
      </div>
    <% end %>

  </div>
</div>
