<%= form_with model: [:admin, manga], class: 'space-y-5' do |f| %>
  <% if manga.errors.any? %>
    <div
      class='
        bg-red-900/40 border border-red-700 rounded p-4 text-red-300 text-sm
      '
    >
      <% manga.errors.full_messages.each do |msg| %><p><%= msg %></p><% end %>
    </div>
  <% end %>
  <div>
    <%= f.label :title, class: "block text-sm text-zinc-300 mb-1" %>
    <%= f.text_field :title,
                 class:
                   "w-full bg-zinc-800 border border-zinc-700
              rounded px-3 py-2 text-zinc-100 text-sm" %>
  </div>
  <div>
    <%= f.label :author, class: "block text-sm text-zinc-300 mb-1" %>
    <%= f.text_field :author,
                 class:
                   "w-full bg-zinc-800 border border-zinc-700
              rounded px-3 py-2 text-zinc-100 text-sm" %>
  </div>
  <div>
    <%= f.label :description, class: "block text-sm text-zinc-300 mb-1" %>
    <%= f.text_area :description,
                rows: 4,
                class:
                  "w-full bg-zinc-800 border
              border-zinc-700 rounded px-3 py-2 text-zinc-100 text-sm resize-none" %>
  </div>
  <div>
    <%= f.label :status, class: "block text-sm text-zinc-300 mb-1" %>
    <%= f.select :status,
             Manga.statuses.keys.map { |s| [s.humanize, s] },
             {},
             class:
               "w-full bg-zinc-800 border border-zinc-700 rounded
                          px-3 py-2 text-zinc-100 text-sm" %>
  </div>
  <div>
    <%= f.label :cover_image, class: "block text-sm text-zinc-300 mb-1" %>
    <%= f.file_field :cover_image,
                 accept: "image/*",
                 class:
                   "text-sm text-zinc-400 file:mr-4 file:py-2 file:px-4
                      file:rounded file:border-0 file:bg-zinc-700 file:text-zinc-200
                      file:cursor-pointer hover:file:bg-zinc-600" %>
  </div>
  <%= f.submit class:
             "bg-red-600 hover:bg-red-500 text-white font-semibold
          py-2 px-6 rounded transition cursor-pointer" %>
<% end %>
