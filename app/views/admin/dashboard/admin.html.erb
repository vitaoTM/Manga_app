<h1 class='text-3xl font-bold mb-8'>Dashboard</h1>

<div class='grid grid-cols-3 gap-6 mb-10'>
  <div class='bg-zinc-800 rounded p-6 border border-zinc-700'>
    <p class='text-zinc-400 text-sm mb-1'>Manga</p>
    <p class='text-4xl font-bold'><%= @manga_count %></p>
  </div>
  <div class='bg-zinc-800 rounded p-6 border border-zinc-700'>
    <p class='text-zinc-400 text-sm mb-1'>Chapters</p>
    <p class='text-4xl font-bold'><%= @chapter_count %></p>
  </div>
  <div class='bg-zinc-800 rounded p-6 border border-zinc-700'>
    <p class='text-zinc-400 text-sm mb-1'>Users</p>
    <p class='text-4xl font-bold'><%= @user_count %></p>
  </div>
</div>

<h2 class='text-xl font-semibold mb-4'>Recent Manga</h2>
<div class='space-y-2'>
  <% @recent_mangas.each do |manga| %>
    <div
      class='
        flex items-center justify-between bg-zinc-800 rounded px-4 py-3 border
        border-zinc-700
      '
    >
      <span><%= manga.title %></span>
      <%= link_to "Edit",
      edit_admin_manga_path(manga),
      class: "text-xs text-red-400 hover:text-red-300" %>
    </div>
  <% end %>
</div>
