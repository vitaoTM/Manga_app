<div
  class='
    flex flex-col sm:flex-row items-center justify-between mb-8 gap-4 px-4
  '
>
  <h1 class='text-3xl font-bold'>Admin Dashboard</h1>
  <%= link_to "New Manga",
  new_manga_path,
  class:
    "w-full sm:w-auto text-center bg-red-600 hover:bg-red-500 text-white px-6 py-2 rounded font-semibold transition-colors" %>
</div>

<div class='max-w-6xl mx-auto px-4'>
  <h2 class="text-xl font-bold mb-4 text-slate-100">Manga Management</h2>
  <div class='space-y-3'>
    <% @recent_mangas.each do |manga| %>
      <div
        class='
          flex flex-col sm:flex-row sm:items-center justify-between bg-slate-800/50
          rounded-lg px-4 py-3 border border-slate-700/50 hover:bg-slate-800
          transition-colors gap-3
        '
      >
        <div class="flex items-center gap-3 overflow-hidden">
          <% if manga.cover_image.attached? %>
            <%= image_tag manga.cover_image.variant(resize_to_fill: [40, 60]).processed,
            class: "rounded w-10 h-14 object-cover shrink-0" %>
          <% else %>
            <div
              class="
                w-10 h-14 bg-slate-900 flex items-center justify-center rounded shrink-0
              "
            >📖</div>
          <% end %>
          <span class='font-medium text-slate-200 truncate'>
            <%= link_to manga.title, manga_path(manga), class: "hover:text-white" %>
          </span>
        </div>

        <div
          class='
            flex items-center justify-between sm:justify-end gap-4 text-sm w-full sm:w-auto
          '
        >
          <span class='text-slate-500 bg-slate-900/50 px-2 py-1 rounded'><%= manga.total_chapters %>
            ch</span>
          <div class="flex gap-4">
            <%= link_to "Edit",
            edit_manga_path(manga),
            class: "text-indigo-400 hover:text-indigo-300 font-medium" %>
            <%= button_to "Delete",
            manga_path(manga),
            method: :delete,
            data: {
              turbo_confirm: "Delete this manga?",
            },
            class:
              "text-red-400 hover:text-red-300 bg-transparent border-0 cursor-pointer font-medium" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <%# Donations Section %>
  <div
    class="
      bg-slate-900/40 rounded-xl p-4 sm:p-8 border border-slate-800/60 mt-12 shadow-sm
      overflow-hidden
    "
  >
    <h2 class="text-xl font-bold mb-8 text-slate-100">Donations Summary</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
      <div class="bg-slate-950/40 p-5 rounded-lg border border-slate-800/50">
        <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider mb-2">Total raised</p>
        <p class="text-2xl font-black text-green-500">
          <span class="text-xl font-bold opacity-80 mr-1">R$</span><%= format("%.2f", (@donation_total || 0) / 100.0) %>
        </p>
      </div>
      <div class="bg-slate-950/40 p-5 rounded-lg border border-slate-800/50">
        <p class="text-slate-500 text-xs font-semibold uppercase tracking-wider mb-2">Total Donations</p>
        <p class="text-2xl font-black text-slate-100"><%= @donation_count || 0 %></p>
      </div>
    </div>

    <% if @recent_donations&.any? %>
      <div class="space-y-3">
        <div
          class="
            hidden md:grid grid-cols-12 gap-4 px-5 py-2 text-xs font-bold uppercase
            tracking-wider text-slate-500
          "
        >
          <div class="col-span-3">User</div>
          <div class="col-span-5">Message</div>
          <div class="col-span-2 text-right">Amount</div>
          <div class="col-span-2 text-right">Date</div>
        </div>

        <% @recent_donations.each do |donation| %>
          <div
            class="
              flex flex-col md:grid md:grid-cols-12 items-start md:items-center gap-2 md:gap-4
              px-4 sm:px-5 py-3.5 bg-slate-950/30 rounded-lg border border-slate-800/40
              hover:bg-slate-900/40 transition-colors
            "
          >
            <div class="col-span-3 w-full md:w-auto">
              <span class="text-slate-200 font-medium block md:inline">
                <%= donation.user&.username || "Guest" %>
              </span>
              <span class="md:hidden text-slate-600 text-[10px] ml-2"><%= donation.created_at.strftime("%b %d, %Y") %></span>
            </div>

            <div class="col-span-5 w-full">
              <% if donation.message.present? %>
                <span
                  class="
                    text-slate-500 text-sm italic line-clamp-1 md:line-clamp-2
                  "
                  title="<%= donation.message %>"
                >
                  "<%= donation.message %>"
                </span>
              <% end %>
            </div>

            <div
              class="
                col-span-2 md:text-right w-full md:w-auto flex justify-between md:block
              "
            >
              <span class="md:hidden text-slate-600 text-xs font-bold uppercase">Amount:</span>
              <span class="text-sm text-green-500 font-bold tabular-nums">
                <%= donation.amount_display %>
              </span>
            </div>

            <div class="hidden md:block col-span-2 text-right">
              <span class="text-slate-600 text-xs font-medium">
                <%= donation.created_at.strftime("%b %d, %Y") %>
              </span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div
        class="
          text-center py-12 bg-slate-950/20 rounded-lg border border-dashed
          border-slate-800
        "
      >
        <p class="text-slate-500 text-sm italic">No donations yet.</p>
      </div>
    <% end %>
  </div>
</div>
