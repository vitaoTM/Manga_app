<div class='flex items-center justify-between mb-6'>
  <h1 class='text-2xl font-bold'>Manga</h1>
  <%= link_to "New Manga",
  admin_dashboard_path,
  class: "bg-red-600 text-white px-4 py-2 rounded text-sm" %>
</div>
<div class='space-y-2'>
  <% @recent_mangas.each do |manga| %>
    <div
      class='
        flex items-center justify-between bg-zinc-800 rounded px-4 py-3 border
        border-zinc-700
      '
    >
      <span class='font-medium'><%= manga.title %></span>
      <div class='flex gap-3 text-sm'>
        <span class='text-zinc-500'><%= manga.total_chapters %>
          ch</span>
        <%= link_to "Edit", edit_manga_path(manga), class: "text-red-400 hover:text-red-300" %>
        <%= button_to "Delete",
        admin_dashboard_path(manga),
        method: :delete,
        data: {
          turbo_confirm: "Delete this manga?",
        },
        class: "text-red-400 hover:text-red-300 bg-transparent border-0 cursor-pointer" %>
      </div>
    </div>
  <% end %>
</div>
