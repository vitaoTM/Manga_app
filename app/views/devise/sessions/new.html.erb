<div
  class="
    min-h-[calc(100vh-4rem)] flex items-center justify-center bg-slate-900 px-4
  "
>
  <div
    class="
      w-full max-w-sm bg-slate-800 p-8 rounded-lg shadow-xl border border-slate-700
    "
  >

    <h2 class="text-2xl font-bold text-white mb-6 text-center">Log in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-5" }) do |f| %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-slate-300 mb-1" %>
        <%= f.email_field :email,
                      autofocus: true,
                      autocomplete: "email",
                      class:
                        "w-full px-4 py-2 bg-slate-900 border border-slate-700 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent placeholder-slate-500 transition duration-150 ease-in-out" %>
      </div>

      <div>
        <%= f.label :password, class: "block text-sm font-medium text-slate-300 mb-1" %>
        <%= f.password_field :password,
                         autocomplete: "current-password",
                         class:
                           "w-full px-4 py-2 bg-slate-900 border border-slate-700 rounded-md text-white focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent placeholder-slate-500 transition duration-150 ease-in-out" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <%= f.check_box :remember_me,
                      class:
                        "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-slate-600 rounded bg-slate-900" %>
          <%= f.label :remember_me, class: "ml-2 block text-sm text-slate-400" %>
        </div>
      <% end %>

      <div>
        <%= f.submit "Log in",
                 class:
                   "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer transition duration-150" %>
      </div>
    <% end %>

    <div class="mt-6 text-center text-sm">
      <div class="space-y-2 text-indigo-400 hover:text-indigo-300">
        <%= render "devise/shared/links" %>
      </div>
    </div>
  </div>
</div>
