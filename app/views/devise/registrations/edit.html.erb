<div class="min-h-screen bg-slate-900 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-2xl mx-auto space-y-8">

    <div>
      <h2 class="text-3xl font-bold text-white">Profile Settings</h2>
      <p class="mt-2 text-sm text-slate-400">Manage your account information and security.</p>
    </div>

    <div
      class="
        bg-slate-800 shadow overflow-hidden sm:rounded-lg border border-slate-700
      "
    >
      <div class="px-4 py-5 sm:p-6">

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put, multipart: true, class: "space-y-6" }) do |f| %>

          <% if resource.errors.any? %>
            <div
              class="
                bg-red-900/30 border border-red-500/50 text-red-200 px-4 py-3 rounded text-sm
              "
            >
              <%= render "devise/shared/error_messages", resource: resource %>
            </div>
          <% end %>

          <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">

            <div class="sm:col-span-3">
              <div class="sm:col-span-3">
                <%= f.label :username,
                        "Username",
                        class: "block text-sm font-medium text-slate-300 px-3" %>
                <div class="mt-1 flex rounded-md shadow-sm">
                  <span
                    class="
                      inline-flex items-center px-3 rounded-l-md border border-r-0 border-slate-600
                      bg-slate-700 text-slate-400 sm:text-sm
                    "
                  >
                    @
                  </span>
                  <%= f.text_field :username,
                               autocomplete: "username",
                               class:
                                 "flex-1 focus:ring-indigo-500 focus:border-indigo-500 block w-full min-w-0 rounded-none rounded-r-md sm:text-sm border-slate-600 bg-slate-900 text-white px-3" %>
                </div>
              </div>
            </div>

            <div class="sm:col-span-6">
              <%= f.label :email, class: "block text-sm font-medium text-slate-300" %>
              <div class="mt-1">
                <%= f.email_field :email,
                              autocomplete: "email",
                              class:
                                "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-slate-600 rounded-md bg-slate-900 text-white px-3" %>
              </div>
              <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
                <div class="mt-2 text-sm text-yellow-400">
                  Currently waiting confirmation for:
                  <%= resource.unconfirmed_email %>
                </div>
              <% end %>
            </div>

          </div>

          <hr class="border-slate-700 my-6">

          <div class="space-y-6">
            <h3 class="text-lg font-medium leading-6 text-white">Change Password</h3>

            <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-6">
              <div class="sm:col-span-3">
                <%= f.label :password,
                        "New Password",
                        class: "block text-sm font-medium text-slate-300" %>
                <div class="mt-1">
                  <%= f.password_field :password,
                                   autocomplete: "new-password",
                                   class:
                                     "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-slate-600 rounded-md bg-slate-900 text-white px-3" %>
                </div>
                <p class="mt-1 text-xs text-slate-500">Leave blank if you don't want to change it.</p>
              </div>

              <div class="sm:col-span-3">
                <%= f.label :password_confirmation,
                        "Confirm New Password",
                        class: "block text-sm font-medium text-slate-300" %>
                <div class="mt-1">
                  <%= f.password_field :password_confirmation,
                                   autocomplete: "new-password",
                                   class:
                                     "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-slate-600 rounded-md bg-slate-900 text-white px-3" %>
                </div>
              </div>
            </div>
          </div>

          <hr class="border-slate-700 my-6">

          <div>
            <%= f.label :current_password, class: "block text-sm font-medium text-slate-300" %>
            <div class="mt-1">
              <%= f.password_field :current_password,
                               autocomplete: "current-password",
                               class:
                                 "shadow-sm focus:ring-indigo-500 focus:border-indigo-500 block w-full sm:text-sm border-slate-600 rounded-md bg-slate-900 text-white" %>
            </div>
            <p class="mt-2 text-sm text-slate-400">We need your current password to confirm your changes.</p>
          </div>

          <div class="flex justify-end">
            <%= link_to "Cancel",
            :back,
            class:
              "bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 mr-3" %>
            <%= f.submit "Update Profile",
                     class:
                       "inline-flex justify-center py-2 px-4 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
          </div>
        <% end %>
      </div>
    </div>

    <div
      class="
        bg-red-900/10 shadow sm:rounded-lg border border-red-900/30 overflow-hidden
      "
    >
      <div class="px-4 py-5 sm:p-6">
        <h3 class="text-lg leading-6 font-medium text-red-400">Danger Zone</h3>
        <div class="mt-2 max-w-xl text-sm text-slate-400">
          <p>Once you delete your account, there is no going back. Please be
            certain.</p>
        </div>
        <div class="mt-5">
          <%= button_to "Delete my account",
          registration_path(resource_name),
          data: {
            confirm: "Are you sure?",
            turbo_confirm: "Are you sure?",
          },
          method: :delete,
          class:
            "inline-flex items-center justify-center px-4 py-2 border border-transparent font-medium rounded-md text-red-200 bg-red-900/50 hover:bg-red-900 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 sm:text-sm transition-colors cursor-pointer" %>
        </div>
      </div>
    </div>

  </div>
</div>
