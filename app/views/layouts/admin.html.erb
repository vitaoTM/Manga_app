<!DOCTYPE html>
<html>
  <head>
    <title>Admin — Manga App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-slate-950 text-slate-100 min-h-screen">
    <%= render "shared/navbar" %>
    <main class="max-w-6xl mx-auto px-6 py-10">
      <% if notice.present? %>
        <p
          class="
            bg-emerald-900/40 border border-emerald-700 text-emerald-300 text-sm px-4 py-3
            rounded mb-6
          "
        ><%= notice %></p>
      <% end %>
      <% if alert.present? %>
        <p
          class="
            bg-red-900/40 border border-red-700 text-red-300 text-sm px-4 py-3 rounded mb-6
          "
        ><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
