<!DOCTYPE html>
<html>
  <head>
    <title>Admin — Manga App</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>
  <body class="bg-zinc-950 text-zinc-100 min-h-screen">
    <nav class=" bg-zinc-900 border-b border-zinc-800 px-6">
      <div id="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

            <span class="font-bold text-red-500"><%= link_to "ADMIN", admin_dashboard_path %></span>

            <div class="flex gap-4 text-sm">
              <%= link_to "View Site", root_path, class: "text-zinc-400 hover:text-white" %>
              <%= link_to "Sign out",
              destroy_user_session_path,
              data: {
                turbo_method: :delete,
              },
              class: "text-zinc-400 hover:text-white" %>
            </div>

          </div>
        </div>
      </div>
    </nav>
    <main class="max-w-6xl mx-auto px-6 py-10">
      <% if notice.present? %>
        <p
          class="
            bg-emerald-900/40 border border-emerald-700 text-emerald-300 text-sm px-4 py-3
            rounded mb-6
          "
        ><%= notice %></p>
      <% end %>
      <% if alert.present? %>
        <p
          class="
            bg-red-900/40 border border-red-700 text-red-300 text-sm px-4 py-3 rounded mb-6
          "
        ><%= alert %></p>
      <% end %>
      <%= yield %>
    </main>
  </body>
</html>
